# pyenv
#   For a library or app, you might want to share your .python-version.
#   Otherwise, uncomment the line below.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing pipenv install --ignore-pipfile, you can ignore Pipfile.lock.
#   Uncomment the line below if you wish to ignore it.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended to be committed.
#   Uncomment the line below if you wish to ignore it.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally recommended to be committed.
#pdm.lock
#   pdm build pack tracking file
.pdm-plugins/

# PEP 582; used by e.g. github.com/lincolnloop/layman and github.com/pdm-project/pdm
__pypackages__/

